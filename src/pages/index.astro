---
// src/pages/index.astro
import SlideLayout from '../layouts/SlideLayout.astro';
import MobileUI from '../components/MobileUI.astro';

import { getImage } from "astro:assets";
import pplsGuideImg from "../assets/images/peoples_guide_page.webp";
import slide01Img from "../assets/images/Slide01.png";
import slide02Img from "../assets/images/Slide02.png";
import slide03Img from "../assets/images/Slide03.png";
import slide04Img from "../assets/images/Slide04.png";
import slide05Img from "../assets/images/Slide05.png";
import slide06Img from "../assets/images/Slide06.png";
import slide07Img from "../assets/images/Slide07.png";
import slide08Img from "../assets/images/Slide08.png";
import slide09Img from "../assets/images/Slide09.png";
import slide10Img from "../assets/images/Slide10.png";
import slide11Img from "../assets/images/Slide11.png";
import slide12Img from "../assets/images/Slide12.png";

// This generates a guaranteed URL that works on remote servers
const optimizedBackground = await getImage({ src: pplsGuideImg });
---

<SlideLayout title="Material 3 Presentation">
<!-- Slide Desc -->
<section 
  data-background-size="80%"
  data-background-image={slide01Img.src /* <- use optimizedBackground.src on server, to display locally use slideXXImg.src */}>
</section>

<!-- Slide Desc -->
