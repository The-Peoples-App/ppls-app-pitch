---
interface ObjectProps {
  img: any;
  x: number; // Figma X
  y: number; // Figma Y
  width: number;
  dataId: string; // Required for smooth Auto-Animate
  animation?: 'fade-up' | 'fade-down' | 'fade-left' | 'fade-right'; // Restrict types for predictable CSS
  autoplay?: boolean;
  fetchPriority?: boolean;
  css?: string;
}

interface Props {
  bgImg: any;
  objects: ObjectProps[];
  gridClass?: string;
  preloadBackground?: boolean;
}

const {
  bgImg,
  objects,
  gridClass = 's12 m12',
  preloadBackground = false,
} = Astro.props;

import { Image, getImage } from 'astro:assets';

// Generate optimized responsive background srcset
const optimizedBg = await getImage({
  src: bgImg,
  width: 1920,
  widths: [1024, 2048, 4096], // Build 1x, 2x, 4x versions
});

const bgImageSrc = optimizedBg.src;
const bgImageSrcset = optimizedBg.srcSet.attribute;
const bgImageSizes = '100vw';

// Build <link rel="preload" ...> (preload 1st slide bg image)
let preloadScript = '';
if (preloadBackground) {
  preloadScript = `
    <script>
      (function() {
        const link = document.createElement('link');
        link.rel = 'preload';
        link.as = 'image';
        link.href = '${bgImageSrc}';
        link.setAttribute('imagesrcset', '${bgImageSrcset}');
        link.setAttribute('imagesizes', '${bgImageSizes}');
        link.setAttribute('fetchpriority', 'high');
        document.head.appendChild(link);
      })();
    </script>
  `;
}
---

<!-- Add <link rel="preload"...> to <head> -->
<Fragment set:html={preloadScript} />

<div
  class={`${gridClass} stage-cell`}
  data-id='stable-figma-stage'
  style={`background-image: url(${bgImageSrc});`}
>
  {
    objects.map((obj, index) => {
      // Determine the animation class based on whether it is autoplaying or manual
      const animationClass = obj.animation || null;
      const isAutoplay = obj.autoplay ?? false;
      const customCSS = obj.css || null;
      const fetchPriority = obj.fetchPriority || null;

      return (
        <Image
          src={obj.img}
          width={obj.width}
          widths={[obj.width, obj.width * 2]}
          alt='Slide Object'
          data-id={obj.dataId}
          loading={preloadBackground ? 'eager' : 'lazy'}
          priority={fetchPriority}
          class:list={[
            'floating-object',
            animationClass,
            { 'fragment': !isAutoplay, 'autoplay-animation': isAutoplay },
          ]}
          style={`
      left: ${obj.x}px;
      top: ${obj.y}px;
      width: ${obj.width}px;
      height: auto;
      --delay: ${index * 0.15}s;
      ${customCSS || ''}
    `}
        />
      );
    })
  }
</div>

<style>
  .stage-cell {
    position: relative;
    background-size: cover;
    background-position: center;
    width: 1920px;
    height: 1080px;
    overflow: hidden;
    contain: layout size style;
    margin-block-start: 0px !important; /* Overrides aggressive Beer CSS spacing */
  }

  .floating-object {
    position: absolute;
    display: block;
    margin: 0 !important; /* Neutralizes Reveal's theme margins */
    /* Force GPU layer caching to stop image dropping */
    transform: translate3d(0, 0, 0);
  }

  /* --- Manual Reveal.js Fragments --- */
  .fragment {
    transition-delay: var(--delay);
  }

  /* --- Selectable Autoplay Logic --- */
  /* 1. Base state for autoplay items (hidden & shifted) */
  .autoplay-animation {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: var(--delay);
  }

  .autoplay-animation.fade-up {
    transform: translateY(40px);
  }
  .autoplay-animation.fade-down {
    transform: translateY(-40px);
  }
  .autoplay-animation.fade-left {
    transform: translateX(40px);
  }
  .autoplay-animation.fade-right {
    transform: translateX(-40px);
  }

  /* 2. Active state (Triggers immediately when Reveal.js adds .present to the parent slide) */
  :global(.present) .autoplay-animation {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>
