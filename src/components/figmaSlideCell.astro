---
interface ObjectProps {
  img: any;
  x: number; // Figma X
  y: number; // Figma Y
  width: number;
  dataId: string; // Required for smooth Auto-Animate
  animation?: 'fade-up' | 'fade-down' | 'fade-left' | 'fade-right';
  autoplay?: boolean;
  fetchPriority?: boolean;
  css?: string;
}

interface Props {
  bgImg: any;
  tileBgImg?: any;
  objects: ObjectProps[];
  gridClass?: string;
  preloadBackground?: boolean;
}

const {
  bgImg,
  tileBgImg,
  objects,
  gridClass = 's12 m12',
  preloadBackground = false,
} = Astro.props;

import { Image, getImage } from 'astro:assets';

// Generate optimized responsive background srcset
const optimizedBg = await getImage({
  src: bgImg,
  width: 1920,
  format: 'webp',
});

const bgImageSrc = optimizedBg.src;
const tileBgSrc = tileBgImg ? tileBgImg.src : '';
const tileBgStyles =
  tileBgImg ? `background-size: auto; --tileBgImgSrc: url(${tileBgSrc})` : '';

// Build <link rel="preload" ...> (preloading slide backgrounds)
let preloadScript = '';
if (preloadBackground) {
  preloadScript = `
    <!-- Add <link rel="preload"...> to <head> -->
    <script>
      (function() {
        const link = document.createElement('link');
        link.rel = 'preload';
        link.as = 'image';
        link.href = '${bgImageSrc}';
        link.setAttribute('fetchpriority', 'high');
        document.head.appendChild(link);
      })();
    </script>
  `;
}
---

<Fragment set:html={preloadScript} />

<div
  class={`${gridClass} ${tileBgImg ? 'stage-cell-tiled-bg' : 'stage-cell'}`}
  data-id='stable-figma-stage'
  style={`background-image: url(${tileBgImg ? 'none' : bgImageSrc}); ${tileBgImg ? tileBgStyles : ''}`}
>
  {
    objects.map((obj, index) => {
      // Determine animation class based on autoplaying or manual
      const animationClass = obj.animation || null;
      const isAutoplay = obj.autoplay ?? false;
      const customCSS = obj.css || null;
      const fetchPriority = obj.fetchPriority || null;

      return (
        <Image
          src={obj.img}
          width={obj.width}
          widths={[obj.width, obj.width * 2]}
          sizes={`${obj.width}px`}
          alt='Slide Object'
          data-id={obj.dataId}
          loading={preloadBackground ? 'eager' : 'lazy'}
          priority={fetchPriority}
          class:list={[
            'floating-object',
            animationClass,
            { 'fragment': !isAutoplay, 'autoplay-animation': isAutoplay },
          ]}
          style={`
                  left: ${obj.x}px;
                  top: ${obj.y}px;
                  width: ${obj.width}px;
                  height: auto;
                  --delay: ${index * 0.15}s;
                  ${customCSS || ''}
               `}
        />
      );
    })
  }
</div>

<style>
  .stage-cell {
    position: relative;
    background-size: cover;
    background-position: center;
    width: 1920px;
    height: 1080px;
    overflow: hidden;
    contain: layout size style;
    margin-block-start: 0px !important; /* Overrides aggressive Beer CSS spacing */
  }

  /* STAGE CELL IF TILED BG */
  .stage-cell-tiled-bg {
    position: relative;
    width: 1920px;
    height: 1080px;
    overflow: hidden; /* Hides the extra background outside the box */
    background-color: #241e4e; /* Dark background fallback */
    z-index: -3; /* Sits below LAYER 1 & LAYER 2 of bg */
  }

  /* LAYER 1: The rotated purple ellipse gradient (Bottom Layer) */
  .stage-cell-tiled-bg::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -10%;
    width: 120%;
    height: 200%;

    background-image: radial-gradient(ellipse 75% 38%, #352c72, #241e4e);
    transform: rotate(19deg);
    z-index: -2; /* Sits at the bottom */
  }

  /* LAYER 2: The cube-tile image at 16% visibility (Middle Layer) */
  .stage-cell-tiled-bg:after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: var(--tileBgImgSrc);
    opacity: 0.16;
    z-index: -1; /* Sits on top of gradient */
    pointer-events: none; /* Prevent layer from blocking mouse clicks */
  }

  .floating-object {
    position: absolute;
    display: block;
    margin: 0 !important; /* Neutralizes Reveal's theme margins */
    /* Force GPU layer caching to stop image dropping */
    transform: translate3d(0, 0, 0);
  }

  /* Manual Reveal.js Fragments */
  .fragment {
    transition-delay: var(--delay);
  }

  /* --- Selectable Autoplay Logic --- */
  /* 1. Base state for autoplay items (hidden & shifted) */
  .autoplay-animation {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
    transition-delay: var(--delay);
  }

  .autoplay-animation.fade-up {
    transform: translateY(40px);
  }
  .autoplay-animation.fade-down {
    transform: translateY(-40px);
  }
  .autoplay-animation.fade-left {
    transform: translateX(40px);
  }
  .autoplay-animation.fade-right {
    transform: translateX(-40px);
  }

  /* 2. Active state (Animate on Reveal .present on parent) */
  :global(.present) .autoplay-animation {
    opacity: 1;
    transform: translate(0, 0);
  }
</style>
