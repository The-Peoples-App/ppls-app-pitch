---
// src/components/DualLayerView.astro
const { id, highFiSrc, blueprintSrc, title } = Astro.props;
---

<section class="feature-section" id={`section-${id}`}>
  <h2>{title}</h2>
  <div class="scroll-container">
    <div class="sticky-container">
      <div class="layer-wrapper">
        <div class="hifi-layer">
          <img src={highFiSrc} alt={`High-fidelity view of ${title}`} />
        </div>
        <div class="blueprint-layer">
          <img src={blueprintSrc} alt={`Blueprint architecture of ${title}`} />
        </div>
      </div>
    </div>
    <div class="content-spacer"></div>
  </div>
</section>

<style is:global>
  .feature-section {
    margin-bottom: 32px; /* Following 8dp grid */
  }
  
  .scroll-container {
    position: relative;
    height: 150vh; /* Makes section twice the height of viewport for scrolling effect */
  }
  
  .sticky-container {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
  }
  
  .layer-wrapper {
    position: relative;
    width: 1920px;
    height: 1080px;
    max-width: 100%;
    max-height: 90vh;
  }
  
  .hifi-layer, .blueprint-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  
  .hifi-layer {
    z-index: 1;
  }
  
  .blueprint-layer {
    z-index: 2;
    opacity: 0; /* Start with blueprint hidden */
    /* transition: opacity 300ms cubic-bezier(0.4, 0, 0.2, 1); */
    transition: opacity 30ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .content-spacer {
    height: 75vh; /* Creates space for scrolling effect */
  }
  
  img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
</style>

<script define:vars={{ id }}>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById(`section-${id}`);
    const blueprintLayer = section.querySelector('.blueprint-layer');
    const scrollContainer = section.querySelector('.scroll-container');
    
    function updateOpacity() {
      // Get the position of the section relative to the viewport
      const rect = scrollContainer.getBoundingClientRect();
      
      // Calculate scroll progress through the section
      // Start at 0 when section enters, reach 1 when halfway through
      const scrollProgress = Math.min(1, Math.max(0, 
        1 - (rect.bottom - window.innerHeight) / rect.height * 2
      ));
      
      // Apply opacity to blueprint layer based on scroll progress
      blueprintLayer.style.opacity = scrollProgress.toString();
    }
    
    // Update on scroll
    window.addEventListener('scroll', updateOpacity);
    
    // Initial update
    updateOpacity();
  });
</script>
